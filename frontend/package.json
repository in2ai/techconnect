{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "codegen:models": "cd .. && uv run --package techconnect-schemas export-schema --format typescript --output frontend/src/app/generated/models.ts",
    "ng": "ng",
    "start": "npm run codegen:models && ng serve",
    "start:es": "npm run codegen:models && ng serve --configuration=es",
    "build": "npm run codegen:models && ng build",
    "watch": "npm run codegen:models && ng build --watch --configuration development",
    "test": "npm run codegen:models && ng test",
    "test:e2e": "npm run codegen:models && playwright test",
    "extract-i18n": "npm run codegen:models && ng extract-i18n --output-path src/locale"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/cdk": "~21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/forms": "^21.2.1",
    "@angular/material": "~21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/router": "^21.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@angular/localize": "^21.2.1",
    "@angular/material": "^21.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^25.3.3",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
